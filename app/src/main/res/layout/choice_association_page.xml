<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner Annonce -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/announcement_bg"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/announcement_text"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <include layout="@layout/toolbar_main" />

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/hero_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingVertical="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÉTAPE 1"
                android:textColor="@color/primaryBlue"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Inscrire mon association"
                android:textColor="@color/text_main"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Vous êtes sur le point de créer votre espace Koordy.\nEst-ce bien ce que vous cherchez à faire ?"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <!-- Steps Progress Bar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                <View android:layout_width="40dp" android:layout_height="4dp" android:background="@color/primaryBlue" android:layout_marginEnd="4dp" />
                <View android:layout_width="40dp" android:layout_height="4dp" android:background="#E0E0E0" android:layout_marginEnd="4dp" />
                <View android:layout_width="40dp" android:layout_height="4dp" android:background="#E0E0E0" android:layout_marginEnd="4dp" />
                <View android:layout_width="40dp" android:layout_height="4dp" android:background="#E0E0E0" android:layout_marginEnd="4dp" />
                <View android:layout_width="40dp" android:layout_height="4dp" android:background="#E0E0E0" />
            </LinearLayout>

        </LinearLayout>

        <!-- Choice Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card 1: Create -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_create_asso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/primaryBlue"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Créer une nouvelle plateforme"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Démarrez la création d’un espace Koordy dédié à votre association. Inscription 100% gratuite."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="›"
                        android:textColor="@color/primaryBlue"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Search/Connect -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_search_asso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rechercher mon association"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Votre association utilise déjà Koordy ? Recherchez-la puis accédez à sa plateforme existante."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="›"
                        android:textColor="@color/primaryBlue"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>