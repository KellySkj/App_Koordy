<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_off_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner Annonce -->
        <TextView
            android:id="@+id/announcement_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/announcement_bg"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/announcement_text"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <include layout="@layout/toolbar_main" />

        <!-- Hero Section -->
        <LinearLayout
            android:id="@+id/hero_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/hero_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hero_subtitle"
                android:textColor="@color/primaryBlue"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/hero_title"
                android:textColor="@color/text_main"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/hero_description"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/hero_cta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primaryBlue"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:text="@string/hero_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="24dp" />

        </LinearLayout>

        <!-- Stats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:baselineAligned="false">

            <!-- Stat 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_asso_label" android:textColor="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_asso_value" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_main" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_asso_desc" android:textColor="@color/text_secondary" android:gravity="center" />
            </LinearLayout>

            <!-- Stat 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_members_label" android:textColor="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_members_value" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_main" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_members_desc" android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Stat 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_solution_label" android:textColor="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_solution_value" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_main" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_solution_desc" android:textColor="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>

        <!-- Features Preview (Bottom) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/feature_create_title" android:textStyle="bold" android:textSize="16sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/feature_create_desc" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- More cards could go here... -->

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>